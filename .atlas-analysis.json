  "keyFeatures": [
    "Real-time latency using QUIC for prioritization and partial reliability",
    "Massive scale with CDN fan-out and cross-region clustering support",
    "Modern web APIs (WebTransport, WebCodecs, WebAudio)",
    "Multi-language with Rust (native) and TypeScript (web) implementations",
    "Generic pub/sub for any live data, not just media",
    "Layered architecture separating transport (moq-lite) from media (hang)",
    "WebRTC-like latency without WebRTC constraints",
    "Built-in authentication via JWT tokens"
  ],
  "publicApiSurface": [
    "moq-lite: Origin, Broadcast, Track, Group, Frame",
    "moq-lite: Client, Server, Session",
    "hang: Catalog, Container, Support",
    "moq-relay: Relay server binary",
    "moq-cli: CLI for publishing media",
    "moq-token: JWT authentication",
    "moq-native: QUIC endpoint configuration",
    "moq-mux: Media muxers (fMP4, CMAF, HLS)",
    "@moq/lite: Connection, Broadcast, Track, Group",
    "@moq/hang: Catalog, Container, Util",
    "@moq/watch: Watch component and API",
    "@moq/publish: Publish component and API",
    "@moq/token: Token generation",
    "@moq/signals: Reactive signals",
    "@moq/ui-core: UI components",
    "libmoq: C bindings for moq-lite"
  ]
